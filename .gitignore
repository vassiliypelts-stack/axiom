# Секреты — НИКОГДА не коммитить
.env
# ...и любые его копии/бэкапы: .env.backup, .env.bak, .env.local, .env.2026-07-15 и т.п.
# Голое «.env» их НЕ ловит — .env.backup с ключами уже лежал untracked и уехал бы
# в историю от одного «git add .».
.env.*
!.env.example
*.session
*.session-journal
twoFA.txt
tdata/
axiom/google_credentials.json
axiom/google_token.json
# Купленные TG-аккаунты (tdata, .json с api/proxy, 2FA, .exe) — СЕКРЕТЫ
ТГ Аккуанты(portable)/
АККАУНТ ТГ 2025новые_08_07/
АККАУНТЫ ТГ/
# Бэкапы БД (axiom.db.bak-*, *.db.bak) — те же секреты (сессии/2FA), что и в самой базе.
# Шаблон *.db их не ловит: имя оканчивается не на .db.
axiom/data/*.bak*
axiom/data/*.db.bak*

# Python
__pycache__/
*.pyc
.venv/
venv/

# Данные и артефакты (тестовая БД, выгрузки, excel)
axiom/data/*.db
axiom/*.db
# SQLite в режиме WAL держит свежие транзакции в -wal/-shm рядом с базой. Шаблон «*.db»
# их НЕ ловит (имя axiom.db-wal), и они уже висели untracked — а внутри те же секреты,
# что и в базе: tg-сессии и 2FA-пароли аккаунтов.
axiom/data/*.db-*
axiom/*.db-*
axiom/data/logs/
# Рантайм-логи прогонов (телефоны/ID лидов) и списки чатов-целей (приватные инвайты) — не код
axiom/data/*.log
axiom/data/parse_targets_*.txt
axiom/data/agentstva_sochi.csv
axiom/data/sample_2gis.csv
axiom/data/kp/
axiom/data/avatars/
axiom/*.xlsx

# Скрапер: ДАННЫЕ и токены (перс.данные лидов + секретный токен) — только код (*.py/*.bat) в репо
axiom/scrapers/*.csv
axiom/scrapers/*.xlsx
axiom/scrapers/*.json
axiom/scrapers/*.txt
# WhatsApp-авторизация (Baileys) — секрет
axiom/../axiom-wa/auth_*/
auth_*/

# Тяжёлые исходные материалы (референс, не код)
Доки Верняка/

# OS
Thumbs.db
.DS_Store
.gstack/
