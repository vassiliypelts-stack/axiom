# Скопируй в .env и заполни. .env НЕ коммитить.

# Claude (Anthropic). Ключ получи в консоли Anthropic. НЕ вставляй ключ в чат.
ANTHROPIC_API_KEY=sk-ant-...
# ⚠️ Сервер в РФ/Беларуси (и, возможно, Казахстане)? api.anthropic.com оттуда закрыт.
# Задай прокси из разрешённой страны — SDK anthropic (httpx) его слушает, а Telethon НЕТ
# (у Telegram свои прокси), поэтому TG не затронется. Пусто = ходим напрямую.
HTTPS_PROXY=              # напр. http://user:pass@host:port  или  socks5://user:pass@host:port
HTTP_PROXY=               # то же значение, что и HTTPS_PROXY (некоторые либы читают его)
# Runtime-модель (обогащение, копайлот) — Haiku, в 5x дешевле, для боя.
AXIOM_MODEL=claude-haiku-4-5
# Модель диалогов агента (где деньги). Можно умнее: claude-sonnet-4-6 / claude-opus-4-8.
AXIOM_AGENT_MODEL=claude-haiku-4-5

# Telegram (дни 3+). Получить на my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_SESSION=axiom_session
# Для сервера: получи строку через `python -m channels.login` и вставь сюда (секрет!)
TG_STRING_SESSION=
TG_PROXY=                # напр. socks5://user:pass@host:port (подойдёт socks5 от proxy6.net)

# Google Calendar / Zoom (дни 5-6). Пусто → встреча фиксируется без ссылки/события.
GOOGLE_CREDENTIALS_FILE=google_credentials.json   # OAuth-клиент типа Desktop из Google Cloud
GOOGLE_TOKEN_FILE=google_token.json               # сюда сохранится токен после 1-го согласия
ZOOM_ACCOUNT_ID=          # Zoom app типа Server-to-Server OAuth, scope meeting:write
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
MEETING_TZ=Europe/Moscow  # таймзона слотов встречи
MEETING_DURATION_MIN=30

# Антибан-лимиты
DAILY_FIRST_MESSAGES=15  # первых сообщений в день на аккаунт

# Вход в веб-пульт (P1 бэклога). Пусто = пульт открыт всем без пароля (только для
# локальной разработки!). На сервере ОБЯЗАТЕЛЬНО задай пароль.
AXIOM_PASSWORD=

# Обогащение: DaData (ИНН/ОГРН/ФИО руководителя из ЕГРЮЛ). Бесплатный ключ на dadata.ru.
DADATA_API_KEY=

# Авто-фото профиля аккаунтов (сток + ИИ-лицо микс, по полу из имени). Хватит
# одного из двух — если нет ни одного, шаг фото просто пропускается.
PEXELS_API_KEY=          # бесплатный ключ: pexels.com/api
GEMINI_API_KEY=          # бесплатный ключ: aistudio.google.com (генерация синтетических лиц)
