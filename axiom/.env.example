# Скопируй в .env и заполни. .env НЕ коммитить.

# Claude (Anthropic). Ключ получи в консоли Anthropic. НЕ вставляй ключ в чат.
ANTHROPIC_API_KEY=sk-ant-...
# Модель агента. По умолчанию opus 4.8. Для экономии на объёме можно claude-sonnet-4-6.
AXIOM_MODEL=claude-opus-4-8

# Telegram (дни 3+). Получить на my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_SESSION=axiom_session
TG_PROXY=                # напр. socks5://user:pass@host:port

# Google Calendar / Zoom (дни 5-6)
GOOGLE_CREDENTIALS_FILE=google_credentials.json
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Антибан-лимиты
DAILY_FIRST_MESSAGES=15  # первых сообщений в день на аккаунт
